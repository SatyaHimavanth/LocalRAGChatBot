# Runtime model paths. Leave blank to use the bundled models under models\.
# CHAT_MODEL_PATH=C:\path\to\chat-model.gguf
# EMBED_MODEL_PATH=C:\path\to\embedding-model.gguf

# SQLite database filename only (not a path). Default: ragapp.db
DB_FILE_NAME=ragapp.db

# Chat context tokens. Leave blank for the automatic memory-based value, or set
# an integer of at least 4096 (for example: 4096, 8192, 16384, or 32768).
# CHAT_CONTEXT_SIZE=8192

# Optional persistent log file. Leave blank (the default), "off", or "stderr"
# to avoid creating a log file; stderr remains available for command redirection.
# LOG_FILE=logs\localragchatbot.log

# Build-only CGO configuration. Required when compiling llama-go on Windows.
# CGO_ENABLED: 1 enables CGO; 0 disables it (the app will not build with llama-go).
CGO_ENABLED=1
CC=gcc
CXX=g++
# Directories containing the locally built llama-go binding library and headers.
# LIBRARY_PATH=C:\path\to\LocalRAGChatBot\third_party\llama-go
# C_INCLUDE_PATH=C:\path\to\LocalRAGChatBot\third_party\llama-go

# Optional operating-system data locations (normally set by the OS, not .env).
# APPDATA=C:\Users\your-user\AppData\Roaming       # Windows database fallback
# XDG_DATA_HOME=/home/your-user/.local/share          # Linux database fallback
