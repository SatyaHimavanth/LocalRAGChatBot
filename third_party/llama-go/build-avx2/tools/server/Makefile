.PHONY : server.i

# target to preprocess a source file
server.cpp.i:
	cd /d C:\Users\hp\Desktop\Projects\LocalRAGChatBot\third_party\llama-go\build-avx2 && $(MAKE) $(MAKESILENT) -f tools\server\CMakeFiles\llama-server-impl.dir\build.make tools/server/CMakeFiles/llama-server-impl.dir/server.cpp.i
.PHONY : server.cpp.i

server.s: server.cpp.s
.PHONY : server.s

# target to generate assembly for a file
server.cpp.s:
	cd /d C:\Users\hp\Desktop\Projects\LocalRAGChatBot\third_party\llama-go\build-avx2 && $(MAKE) $(MAKESILENT) -f tools\server\CMakeFiles\llama-server-impl.dir\build.make tools/server/CMakeFiles/llama-server-impl.dir/server.cpp.s
.PHONY : server.cpp.s

